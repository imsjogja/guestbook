# GuestFlow Environment Configuration
# Copy this file to .env and update the values for your environment

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=GuestFlow
APP_ENV=development
APP_VERSION=1.0.0
APP_DEBUG=true
APP_PUBLIC_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=30s

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=guestflow
DB_PASSWORD=changeme
DB_NAME=guestflow
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_RETRIES=3

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h
JWT_ISSUER=guestflow
JWT_AUDIENCE=guestflow-api

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST=20
RATE_LIMIT_TTL=60s

# ------------------------------------------------------------------------------
# WhatsApp Business API
# ------------------------------------------------------------------------------
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ------------------------------------------------------------------------------
# Email (SMTP)
# ------------------------------------------------------------------------------
# Zoho Mail organization mailbox: use the mailbox address and an app-specific
# password generated from Zoho Accounts > Security > Application Specific Passwords.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_USER=your-mailbox@guestflow.id
EMAIL_PASSWORD=your-zoho-app-specific-password
EMAIL_FROM=your-mailbox@guestflow.id
EMAIL_FROM_NAME=GuestFlow
EMAIL_USE_TLS=true

# ------------------------------------------------------------------------------
# Storage (S3-compatible)
# ------------------------------------------------------------------------------
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=guestflow-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BASE_URL=http://localhost:8080/uploads
STORAGE_LOCAL_PATH=./uploads

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Tenant-ID,X-Request-ID

# ------------------------------------------------------------------------------
# Tenant
# ------------------------------------------------------------------------------
TENANT_HEADER=X-Tenant-ID
TENANT_DEFAULT_SUBDOMAIN=api

# ------------------------------------------------------------------------------
# Graceful Shutdown
# ------------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30s
